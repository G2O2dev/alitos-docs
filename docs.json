{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Alitos",
  "colors": {
    "primary": "#fcb92c",
    "light": "#f2f2fa",
    "dark": "#aaa9a6"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#F5F5F5",
      "dark": "#000000"
    }
  },
  "fonts": {
    "body": {
      "family": "Montserrat",
      "weight": 400
    },
    "heading": {
      "family": "Montserrat",
      "weight": 500
    }
  },
  "favicon": "https://media.brand.dev/235cbe43-9803-43b3-b518-92618b987ae7.png",
  "logo": {
    "light": "https://media.brand.dev/fd0eee97-fe01-405a-ad75-a4f7b4a645cb.png",
    "dark": "https://media.brand.dev/fd0eee97-fe01-405a-ad75-a4f7b4a645cb.png",
    "href": "https://alitos.io"
  },
  "contextual": {
    "options": []
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/cabinets",
              "features/balances",
              "features/filters",
              "features/grouping"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/profile",
              "settings/account"
            ]
          },
          {
            "group": "Mobile",
            "pages": [
              "mobile/overview"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ]
  }
}
