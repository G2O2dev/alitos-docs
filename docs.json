{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Alitos",
  "colors": {
    "primary": "#3374FF",
    "light": "#4D91FF",
    "dark": "#195AE6"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#F5F5F5",
      "dark": "#000000"
    }
  },
  "fonts": {
    "body": {
      "family": "Montserrat",
      "weight": 400
    },
    "heading": {
      "family": "Montserrat",
      "weight": 500
    }
  },
  "favicon": "/logo/favicon.svg",
  "logo": {
    "light": "/logo/alitos.svg",
    "dark": "/logo/alitos.svg",
    "href": "https://alitos.io"
  },
  "contextual": {
    "options": []
  },
  "navigation": {
    "pages": [
      "changelog"
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/changelog"
    }
  ]
}
