{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Alitas",
  "description": "Product updates and release notes for Alitas.",
  "colors": {
    "primary": "#3374FF",
    "light": "#4D91FF",
    "dark": "#195AE6"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#F5F5F5",
      "dark": "#000000"
    }
  },
  "fonts": {
    "body": {
      "family": "Montserrat",
      "weight": 400
    },
    "heading": {
      "family": "Montserrat",
      "weight": 500
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "groups": [
      {
        "group": "Updates",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/changelog"
    }
  ],
  "footer": {
    "socials": {
      "github": "https://github.com/G2O2dev"
    }
  }
}
